# Renombrar a `.env.local` para desarrollo, o cargar en Vercel para producción.

# ───────────────────────────────────────────────────────────────
# Base de datos (Neon Postgres)
# Usar la connection string "pooled" para Vercel functions.
# ───────────────────────────────────────────────────────────────
DATABASE_URL=

# ───────────────────────────────────────────────────────────────
# better-auth
# BETTER_AUTH_SECRET: genera uno con `openssl rand -base64 32`
# BETTER_AUTH_URL: URL base de la app sin slash final
#   - dev: http://localhost:3000
#   - prod: https://tu-dominio.com
# ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ───────────────────────────────────────────────────────────────
# OAuth providers
# Callbacks a registrar:
#   {BETTER_AUTH_URL}/api/auth/callback/google
#   {BETTER_AUTH_URL}/api/auth/callback/github
# ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ───────────────────────────────────────────────────────────────
# Resend (email transaccional para invitaciones)
# El dominio de RESEND_FROM_EMAIL debe estar verificado en Resend.
# ───────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Notify <no-reply@example.com>

# ───────────────────────────────────────────────────────────────
# Bootstrap del SuperAdmin
# Email promovido a admin global al iniciar sesión por primera vez.
# Debe ser un email verificado por el OAuth provider.
# ───────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=


# Kapso
KAPSO_API_KEY=
KAPSO_API_BASE_URL=https://api.kapso.ai
KAPSO_WEBHOOK_SECRET=

# Cloudflare R2 — media saliente del inbox (opcional; requerido para enviar media)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=